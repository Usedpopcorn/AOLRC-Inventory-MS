FLASK_ENV=development
SECRET_KEY=change-me

# Use SUPABASE SESSION POOLER (NOT the direct db.<ref>.supabase.co host)
# Format: postgresql://postgres.<projectref>:PASSWORD@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require