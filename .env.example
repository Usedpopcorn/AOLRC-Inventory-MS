FLASK_ENV=development
SECRET_KEY=change-me
APP_NAME=AOLRC Inventory Management System
APP_BASE_URL=http://127.0.0.1:5000
# Enable only when the app is behind a trusted reverse proxy/tunnel.
TRUST_PROXY_HEADERS=false

# Feature branches use the populated repo-local SQLite database in instance/local_test.db.
DATABASE_URL=sqlite:///local_test.db

# Main can override DATABASE_URL with the shared Postgres value when needed.

# Venue profile file uploads are stored privately and served through guarded app routes.
VENUE_FILE_MAX_BYTES=26214400
# VENUE_FILE_UPLOAD_DIR=/app/instance/venue_files

# Login lockout and throttling. Failed-attempt counters are only meant to protect
# against recent bursts, so stale counters are cleared when no recent failures remain.
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=8
AUTH_LOCKOUT_MINUTES=15
AUTH_LOGIN_ACCOUNT_THROTTLE_LIMIT=10
AUTH_LOGIN_IP_THROTTLE_LIMIT=24
AUTH_LOGIN_THROTTLE_WINDOW_SECONDS=300
LOGIN_EMAIL_2FA_ENABLED=true
LOGIN_2FA_CODE_TTL_MINUTES=10
LOGIN_2FA_MAX_ATTEMPTS=5
LOGIN_2FA_RESEND_COOLDOWN_SECONDS=60
TRUSTED_DEVICE_DAYS_ADMIN=30
TRUSTED_DEVICE_DAYS_STAFF=60
TRUSTED_DEVICE_DAYS_VIEWER=60
TRUSTED_DEVICE_COOKIE_NAME=aolrc_trusted_device
TRUSTED_DEVICE_COOKIE_SAMESITE=Lax

# Development email capture. Docker Compose sends SMTP mail to the Mailpit service.
MAIL_ENABLED=true
MAIL_BACKEND=smtp
MAIL_SERVER=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_DEFAULT_SENDER=AOLRC Inventory <noreply@localhost>
MAIL_SUPPRESS_SEND=false
MAIL_CAPTURE_UI_URL=http://127.0.0.1:8025

# Production SMTP should override the MAIL_* values with provider credentials and
# a verified sender/domain. Never commit real SMTP usernames, passwords, or API keys.
# Suggested live values:
# APP_BASE_URL=https://www.aolrcinventory.org
# MAIL_ENABLED=true
# MAIL_BACKEND=smtp
# MAIL_SERVER=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=<provider_api_key_or_smtp_password>
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_DEFAULT_SENDER=AOLRC Inventory <no-reply@aolrcinventory.org>
# MAIL_SUPPRESS_SEND=false
